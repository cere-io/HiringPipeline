# ===========================================
# Model Provider Configuration
# ===========================================
# MODEL_PROVIDER options: 'gemini' | 'ollama' | 'llamacpp'
# Default: gemini (cloud)

# --- Option 1: Gemini (Cloud) ---
MODEL_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# --- Option 2: Ollama (Local - Recommended for Mac Mini) ---
# MODEL_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434/v1/chat/completions
# OLLAMA_MODEL=qwen2.5:7b

# --- Option 3: llama.cpp (Local) ---
# MODEL_PROVIDER=llamacpp
# LLAMACPP_URL=http://localhost:8080/v1/chat/completions
# LLAMACPP_MODEL=local

# ===========================================
# Notion Integration
# ===========================================
NOTION_API_KEY=your_notion_api_key_here
# NOTION_ROLES_DB_ID=your_roles_database_id
